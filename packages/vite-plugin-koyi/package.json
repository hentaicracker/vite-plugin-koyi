{
    "name": "vite-plugin-koyi",
    "version": "0.1.0",
    "description": "Vite plugin for AI-assisted frontend development with visual DOM context and Claude Code integration",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "pnpm build:client && pnpm build:plugin",
        "build:client": "vite build --config vite.client.config.ts",
        "build:plugin": "vite build --config vite.plugin.config.ts",
        "dev:client": "vite build --config vite.client.config.ts --watch",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "vite": ">=4.0.0"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.36.3",
        "@code-inspector/core": "^1.4.2",
        "react-markdown": "^10.1.0",
        "react-syntax-highlighter": "^16.1.1",
        "remark-gfm": "^4.0.1",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.2",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@types/ws": "^8.5.10",
        "@vitejs/plugin-react": "^4.3.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.4.5",
        "vite": "^5.4.0"
    }
}